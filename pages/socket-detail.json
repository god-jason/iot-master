{
  "title": "通道详情",
  "template": "info",
  "toolbar": [
    {
      "icon": "edit",
      "type": "button",
      "label": "编辑",
      "action": {
        "type": "dialog",
        "page":"socket-edit",
        "params_func": "return {id: data.id, gateway_id: data.gateway_id}",
        "after_close": "this.load()"
      }
    },
    {
      "icon": "play-circle",
      "type": "button",
      "label": "启动",
      "confirm": "确认启动？",
      "action": {
        "type": "script",
        "script": "this.request.post('device/'+this.params.gateway_id+'/action/link', {operator:'open', id:this.params.id}).subscribe(res=>{ })"
      }
    },
    {
      "icon": "stop",
      "type": "button",
      "label": "停止",
      "confirm": "确认停止？",
      "action": {
        "type": "script",
        "script": "this.request.post('device/'+this.params.gateway_id+'/action/link', {operator:'close', id:this.params.id}).subscribe(res=>{ })"
      }
    }
  ],
  "items": [
    {
      "key": "id",
      "label": "ID"
    },
    {
      "key": "name",
      "label": "名称"
    },
    {
      "key": "adapter",
      "label": "网卡"
    },
    {
      "key": "host",
      "label": "主机"
    },
    {
      "key": "port",
      "label": "端口"
    },
    {
      "key": "protocol",
      "label": "协议"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "boolean"
    }
  ],
  "load_api": "table/socket/detail/:id/:gateway_id",
  "tabs": [
    {
      "title": "子设备",
      "page":"device",
      "params_func": "return {gateway_id: params.gateway_id, link_id: params.id}"
    },
    {
      "title": "调试",
      "page":"link-debug",
      "params_func": "return {gateway_id: params.gateway_id, id: params.id}"
    },
    {
      "title": "透传",
      "page":"socket-transport",
      "params_func": "return {gateway_id: params.gateway_id, id: params.id}"
    }
  ]
}
