{
  "title": "版本",
  "template": "table",
  "toolbar": [
    {
      "label": "创建",
      "icon": "plus",
      "type": "button",
      "action": {
        "type": "page",
        "page": "version-create",
        "params_func": "return {product_id: this.params.product_id}"
      }
    },
    {
      "key": "keyword",
      "type": "text",
      "placeholder": "请输入关键字"
    },
    {
      "type": "button",
      "icon": "search",
      "label": "搜索",
      "action": {
        "type": "script",
        "script": "this.keyword=this.toolbar.value.keyword; this.load()"
      }
    }
  ],
  "keywords": [
    "id",
    "name"
  ],
  "operators": [
    {
      "icon": "edit",
      "action": {
        "type": "page",
        "page": "version-edit",
        "params_func": "return {id: data.id}"
      }
    },
    {
      "icon": "delete",
      "title": "删除",
      "confirm": "确认删除？",
      "action": {
        "type": "script",
        "script": "this.request.get('table/version/delete/'+data.id).subscribe(res=>{this.load()})"
      }
    }
  ],
  "batch": true,
  "columns": [
    {
      "key": "id",
      "label": "ID",
      "action": {
        "type": "page",
        "page": "version-detail",
        "params_func": "return {id: data.id}"
      }
    },
    {
      "key": "product_id",
      "label": "产品ID",
      "action": {
        "type": "page",
        "page": "product-detail",
        "params_func": "return {id: data.product_id}"
      }
    },
    {
      "key": "name",
      "label": "名称"
    },
    {
      "key": "description",
      "label": "说明"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "boolean"
    },
    {
      "key": "created",
      "label": "日期",
      "type": "date"
    }
  ],
  "search_api": "table/version/search",
  "mount": "if(this.params.product_id)this.filter.product_id=this.params.product_id; ",
  "methods": {
  }
}
