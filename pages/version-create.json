{
  "title": "创建版本",
  "template": "form",
  "toolbar": [
    {
      "type": "button",
      "label": "选择产品ID",
      "action": {
        "type": "dialog",
        "page": "product-choose",
        "after_close": "this.editor.patchValue({product_id: result.id})"
      }
    }
  ],
  "fields": [
    {
      "key": "id",
      "label": "ID",
      "type": "text",
      "placeholder": "默认随机ID"
    },
    {
      "key": "name",
      "label": "名称",
      "type": "text"
    },
    {
      "key": "description",
      "label": "说明",
      "type": "text"
    },
    {
      "key": "url",
      "label": "固件",
      "type": "file",
      "upload": "/api/upload"
    },
    {
      "key": "product_id",
      "label": "产品ID",
      "type": "text"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "switch"
    }
  ],
  "submit_api": "table/version/create",
  "submit_success": "this.navigate('/page/product-detail?id='+this.data.product_id)",
  "mount": "this.data.product_id=this.params.product_id; ",
  "methods": {
  }
}
