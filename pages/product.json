{
  "title": "产品",
  "template": "table",
  "toolbar": [
    {
      "label": "创建",
      "icon": "plus",
      "type": "button",
      "action": {
        "type": "dialog",
        "page":"product-create",
        "after_close": "this.load()"
      }
    },
    {
      "key": "keyword",
      "type": "text",
      "placeholder": "请输入关键字"
    },
    {
      "type": "button",
      "icon": "search",
      "label": "搜索",
      "action": {
        "type": "script",
        "script": "this.keyword=this.toolbar.value.keyword; this.load()"
      }
    }
  ],
  "keywords": [
    "id",
    "name"
  ],
  "operators": [
    {
      "icon": "eye",
      "action": {
        "type": "dialog",
        "page":"product-detail",
        "params_func": "return {id: data.id}",
        "after_close": "this.load()"
      }
    },
    {
      "icon": "edit",
      "action": {
        "type": "dialog",
        "page":"product-edit",
        "params_func": "return {id: data.id}",
        "after_close": "this.load()"
      }
    },
    {
      "icon": "delete",
      "title": "删除",
      "confirm": "确认删除？",
      "action": {
        "type": "script",
        "script": "this.request.get('table/product/delete/'+data.id).subscribe(res=>{this.load()})"
      }
    }
  ],
  "columns": [
    {
      "key": "id",
      "label": "ID",
      "action": {
        "type": "page",
        "page":"product-detail",
        "params_func": "return {id: data.id}"
      },
      "sortable": true
    },
    {
      "key": "name",
      "label": "名称",
      "sortable": true
    },
    {
      "key": "description",
      "label": "说明"
    },
    {
      "key": "type",
      "label": "类型"
    },
    {
      "key": "version",
      "label": "版本"
    },
    {
      "key": "protocol",
      "label": "协议",
      "sortable": true
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "boolean"
    },
    {
      "key": "created",
      "label": "日期",
      "type": "date",
      "sortable": true
    }
  ],
  "search_api": "table/product/search"
}
