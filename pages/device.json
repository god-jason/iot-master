{
  "title": "设备",
  "template": "table",
  "toolbar": [
    {
      "label": "创建",
      "icon": "plus",
      "type": "button",
      "admin": true,
      "action": {
        "type": "page",
        "page": "device-create",
        "params_func": "return {product_id: this.params.product_id, group_id: this.params.group_id, gateway_id: this.params.gateway_id}"
      }
    },
    {
      "label": "导入",
      "icon": "plus",
      "type": "button",
      "action": {
        "type": "page",
        "page": "device-import"
      }
    },
    {
      "label": "批量删除",
      "icon": "delete",
      "type": "button",
      "admin": true,
      "confirm": "确认批量删除？",
      "action": {
        "type": "script",
        "script": "this.table.selects.forEach(id=>this.request.get('table/device/delete/'+id).subscribe(res=>{this.load()}))"
      }
    },
    {
      "key": "keyword",
      "type": "text",
      "placeholder": "请输入关键字"
    },
    {
      "type": "button",
      "icon": "search",
      "label": "搜索",
      "action": {
        "type": "script",
        "script": "this.keyword=this.toolbar.value.keyword; this.load()"
      }
    }
  ],
  "keywords": [
    "id",
    "name"
  ],
  "operators": [
    {
      "icon": "eye",
      "action": {
        "type": "script",
        "script": "this.navigate('/page/'+(data.gateway_id?'device':'gateway')+'-detail?id='+data.id)"
      }
    },
    {
      "icon": "edit",
      "action": {
        "type": "page",
        "page": "device-edit",
        "params_func": "return {id: data.id}"
      }
    },
    {
      "icon": "delete",
      "title": "删除",
      "confirm": "确认删除？",
      "admin": true,
      "action": {
        "type": "script",
        "script": "this.request.get('table/device/delete/'+data.id).subscribe(res=>{this.load()})"
      }
    }
  ],
  "batch": true,
  "columns": [
    {
      "key": "id",
      "label": "ID",
      "action": {
        "type": "script",
        "script": "this.navigate('/page/'+(data.gateway_id?'device':'gateway')+'-detail?id='+data.id)"
      }
    },
    {
      "key": "product_id",
      "label": "产品ID",
      "action": {
        "type": "page",
        "page": "product-detail",
        "params_func": "return {id: data.product_id}"
      }
    },
    {
      "key": "name",
      "label": "名称"
    },
    {
      "key": "description",
      "label": "说明"
    },
    {
      "key": "online",
      "label": "在线",
      "type": "boolean"
    },
    {
      "key": "error_string",
      "label": "错误"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "boolean"
    },
    {
      "key": "created",
      "label": "日期",
      "type": "date"
    }
  ],
  "search_api": "table/device/search",
  "mounts": [
    "if(this.params.link_id) this.filter.link_id=this.params.link_id;",
    "if(this.params.group_id) this.filter.group_id=this.params.group_id;",
    "if(this.params.product_id) this.filter.product_id=this.params.product_id; ",
    "if(this.params.gateway_id) this.filter.gateway_id=this.params.gateway_id;",
    "if(this.params.gateway_id) this.content.toolbar.push(this.content.sync)",
    "if(!this.params.gateway_id && !this.params.group_id) this.content.toolbar.push(this.content.bind)",
    "if(this.params.group_id) this.content.toolbar.push(this.content.bind_group)",
    "if(this.params.group_id) this.content.toolbar.push(this.content.unbind_group)",
    "if(this.params.group_id) this.content.operators.push(this.content.operator_unbind)",
    "this.get_extend_fields();"
  ],
  "methods": {
    "get_extend_fields": "this.request.get('device/extend/fields').subscribe(res=>{if(res.error)return; res.data.map(f=>this.content.columns.push(f)) })"
  },
  "sync": {
    "label": "下载到网关",
    "icon": "download",
    "type": "button",
    "confirm": "确认下载到网关？",
    "action": {
      "type": "script",
      "script": "this.request.get('device/'+this.params.gateway_id+'/download/device').subscribe(res=>{})"
    }
  },
  "bind": {
    "type": "button",
    "icon": "plus",
    "label": "添加",
    "not_admin": true,
    "action": {
      "type": "dialog",
      "page": "device-bind",
      "after_close": "this.load()"
    }
  },
  "bind_group": {
    "type": "button",
    "icon": "link",
    "label": "绑定",
    "action": {
      "type": "dialog",
      "page": "device-choose",
      "after_close": "result && this.request.get('device/'+result.id+'/bind/'+this.params.group_id).subscribe(res=>this.load())"
    }
  },
  "unbind_group": {
    "label": "批量解绑",
    "icon": "delete",
    "type": "button",
    "confirm": "确认批量解绑？",
    "action": {
      "type": "script",
      "script": "this.table.selects.forEach(id=>this.request.get('device/'+id+'/unbind').subscribe(res=>{this.load()}))"
    }
  },
  "operator_unbind": {
    "icon": "delete",
    "title": "解绑",
    "confirm": "确认解绑？",
    "action": {
      "type": "script",
      "script": "this.request.get('device/'+data.id+'/unbind').subscribe(res=>{this.load()})"
    }
  }
}
