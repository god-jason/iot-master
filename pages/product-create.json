{
  "title": "创建产品",
  "template": "form",
  "fields": [
    {
      "key": "id",
      "label": "ID",
      "type": "text",
      "required": true
    },
    {
      "key": "name",
      "label": "名称",
      "type": "text",
      "required": true
    },
    {
      "key": "description",
      "label": "说明",
      "type": "text"
    },
    {
      "key": "type",
      "label": "类型",
      "type": "text"
    },
    {
      "key": "version",
      "label": "版本",
      "type": "text"
    },
    {
      "key": "protocol",
      "label": "协议",
      "type": "select",
      "options": []
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "switch"
    }
  ],
  "submit_api": "table/product/create",
  "mount": "this.load_protocols()",
  "methods": {
    "load_protocols": "this.request.get('protocol/list').subscribe(res=>{this.content.fields[5].options=res.data.map(d=>{return {value:d.name,label:d.description}}); this.content.fields[5].options.unshift({value:'',label:'无'}); })"
  }
}
