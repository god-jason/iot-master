{
  "title": "导出设备",
  "template": "export",
  "columns": [
    {
      "key": "id",
      "label": "ID",
      "type": "text"
    },
    {
      "key": "product_id",
      "label": "产品ID",
      "type": "text"
    },
    {
      "key": "name",
      "label": "名称",
      "type": "text"
    },
    {
      "key": "description",
      "label": "说明",
      "type": "text"
    },
    {
      "key": "gateway_id",
      "label": "网关ID",
      "type": "text"
    },
    {
      "key": "link_id",
      "label": "连接ID",
      "type": "text"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "switch"
    }
  ],
  "search_api": "table/device/search",
  "mount": "this.get_extend_fields()",
  "methods": {
    "get_extend_fields": "this.request.get('device/extend/fields').subscribe(res=>{if(res.error)return; res.data.map(f=>this.content.columns.push(f)); this.buildForm() })"
  }
}
