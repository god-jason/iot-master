{
  "title": "控制台",
  "children": [
    {
      "content": {
        "template": "statistic",
        "items": [
          {
            "label": "在线",
            "key": "online"
          },
          {
            "label": "离线",
            "key": "offline"
          },
          {
            "label": "错误",
            "key": "error"
          }
        ],
        "mounts":[
          "this.data = {}",
          "this.request.post('table/device/count', {filter:{online:1}}).subscribe(res=>{this.data.online = res.data})",
          "this.request.post('table/device/count', {filter:{online:0}}).subscribe(res=>{this.data.offline = res.data})",
          "this.request.post('table/device/count', {filter:{error:1}}).subscribe(res=>{this.data.error = res.data})"
        ]
      }
    }
  ]
}
