{
  "title": "串口详情",
  "template": "info",
  "toolbar": [
    {
      "icon": "edit",
      "type": "button",
      "label": "编辑",
      "action": {
        "type": "dialog",
        "page":"serial-edit",
        "params_func": "return {id: data.id, gateway_id: data.gateway_id}",
        "after_close": "this.load()"
      }
    },
    {
      "icon": "play-circle",
      "type": "button",
      "label": "启动",
      "confirm": "确认启动？",
      "action": {
        "type": "script",
        "script": "this.request.get('serial/start/'+data.id+'/'+data.gateway_id).subscribe(res=>{})"
      }
    },
    {
      "icon": "stop",
      "type": "button",
      "label": "停止",
      "confirm": "确认停止？",
      "action": {
        "type": "script",
        "script": "this.request.get('serial/stop/'+data.id+'/'+data.gateway_id).subscribe(res=>{})"
      }
    }
  ],
  "items": [
    {
      "key": "id",
      "label": "ID"
    },
    {
      "key": "name",
      "label": "名称"
    },
    {
      "key": "port",
      "label": "序号"
    },
    {
      "key": "baud_rate",
      "label": "波特率"
    },
    {
      "key": "data_bits",
      "label": "字长"
    },
    {
      "key": "stop_bits",
      "label": "停止位"
    },
    {
      "key": "parity",
      "label": "检验位"
    },
    {
      "key": "rs485_gpio",
      "label": "485GPIO"
    },
    {
      "key": "protocol",
      "label": "协议"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "boolean"
    }
  ],
  "load_api": "table/serial/detail/:id/:gateway_id",
  "tabs": [
    {
      "title": "子设备",
      "page":"device",
      "params_func": "return {gateway_id: params.gateway_id, link_id: params.id}"
    },
    {
      "title": "调试",
      "page":"serial-debug",
      "params_func": "return {gateway_id: params.gateway_id, link_id: params.id}"
    },
    {
      "title": "透传",
      "page":"serial-transport",
      "params_func": "return {gateway_id: params.gateway_id, link_id: params.id}"
    }
  ]
}
