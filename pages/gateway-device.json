{
  "title": "子设备",
  "template": "table",
  "toolbar": [

    {
      "label": "创建",
      "icon": "plus",
      "type": "button",
      "action": {
        "type": "dialog",
        "page": "device-create",
        "params_func": "return {product_id: this.params.product_id, group_id: this.params.group_id, gateway_id: this.params.gateway_id}",
        "after_close": "this.load()"
      }
    },
     {
      "label": "导入子设备",
      "icon": "upload",
      "type": "button",
      "action": {
        "type": "page",
        "page": "device-import",
        "params_func": "return {gateway_id: this.params.gateway_id}"
      }
    },

    {
      "label": "批量删除",
      "icon": "delete",
      "type": "button",
      "confirm": "确认批量删除？",
      "action": {
        "type": "script",
        "script": "this.table.selects.forEach(id=>this.request.get('table/device/delete/'+id).subscribe(res=>{this.load()}))"
      }
    },
    {
      "key": "keyword",
      "type": "text",
      "placeholder": "请输入关键字"
    },
    {
      "type": "button",
      "icon": "search",
      "label": "搜索",
      "action": {
        "type": "script",
        "script": "this.keyword=this.toolbar.value.keyword; this.load()"
      }
    },
    {
      "label": "下载到网关",
      "icon": "download",
      "type": "button",
      "confirm": "确认下载到网关？",
      "action": {
        "type": "script",
        "script": "this.request.get('device/'+this.params.gateway_id+'/download/device').subscribe(res=>{})"
      }
    }
  ],
  "keywords": [
    "id",
    "name"
  ],
  "operators": [
    {
      "icon": "eye",
      "action": {
        "type": "dialog",
        "page": "device-detail",
        "params_func": "return {id: data.id}"
      }
    },
    {
      "icon": "edit",
      "action": {
        "type": "dialog",
        "page": "device-edit",
        "params_func": "return {id: data.id}",
        "after_close": "this.load()"
      }
    },
    {
      "icon": "delete",
      "title": "删除",
      "confirm": "确认删除？",
      "action": {
        "type": "script",
        "script": "this.request.get('table/device/delete/'+data.id).subscribe(res=>{this.load()})"
      }
    }
  ],
  "batch": true,
  "columns": [
    {
      "key": "id",
      "label": "ID",
      "action": {
        "type": "script",
        "script": "this.navigate('/page/device-detail?id='+data.id)"
      },
      "sortable": true
    },
    {
      "key": "product_id",
      "label": "产品ID",
      "action": {
        "type": "page",
        "page": "product-detail",
        "params_func": "return {id: data.product_id}"
      },
      "sortable": true
    },
    {
      "key": "name",
      "label": "名称",
      "sortable": true
    },
    {
      "key": "description",
      "label": "说明"
    },
    {
      "key": "online",
      "label": "在线",
      "type": "boolean",
      "sortable": true
    },
    {
      "key": "error_string",
      "label": "错误"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "boolean"
    },
    {
      "key": "created",
      "label": "日期",
      "type": "date",
      "sortable": true
    }
  ],
  "search_api": "table/device/search",
  "mounts": [
    "this.filter.gateway_id=this.params.gateway_id;",
    "this.get_extend_fields();"
  ],
  "methods": {
    "get_extend_fields": "this.request.get('device/extend/fields').subscribe(res=>{if(res.error)return; res.data.map(f=>this.content.columns.push(f)) })"
  }
}
