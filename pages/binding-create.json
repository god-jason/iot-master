{
  "title": "创建数据绑定",
  "template": "form",
  "fields": [
    {
      "key": "id",
      "label": "ID",
      "type": "text",
      "placeholder": "默认随机ID"
    },
    {
      "key": "gateway_id",
      "label": "网关ID",
      "type": "text"
    },
    {
      "key": "name",
      "label": "名称",
      "type": "text"
    },
    {
      "key": "device1",
      "label": "设备1",
      "type": "text"
    },
    {
      "key": "device2",
      "label": "设备2",
      "type": "text"
    },
    {
      "key": "forward",
      "label": "右向",
      "type": "switch"
    },
    {
      "key": "backward",
      "label": "左向",
      "type": "switch"
    }
  ],
  "submit_api": "table/binding/create",
  "mount": "this.data.gateway_id=this.params.gateway_id;"
}
