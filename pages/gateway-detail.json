{
  "title": "设备详情",
  "template": "info",
  "toolbar": [
    {
      "icon": "edit",
      "type": "button",
      "label": "编辑",
      "action": {
        "type": "page",
        "page":"device-edit",
        "params_func": "return {id: data.id}"
      }
    },
    {
      "icon": "delete",
      "type": "button",
      "label": "删除",
      "confirm": "确认删除？",
      "action": {
        "type": "script",
        "script": "this.request.get('table/device/delete/'+data.id).subscribe(res=>{this.navigate('/page/device')})"
      }
    }
  ],
  "items": [
    {
      "key": "id",
      "label": "ID"
    },
    {
      "key": "name",
      "label": "名称"
    },
    {
      "key": "description",
      "label": "说明"
    },
    {
      "key": "product_id",
      "label": "产品ID",
      "action": {
        "type": "page",
        "page":"product-detail",
        "params_func": "return {id: data.product_id}"
      }
    },
    {
      "key": "online",
      "label": "在线",
      "type": "boolean"
    },
    {
      "key": "error_string",
      "label": "错误"
    },
    {
      "key": "disabled",
      "label": "禁用"
    }
  ],
  "load_api": "table/device/detail/:id",
  "tabs": [
    {
      "title": "数据",
      "page":"device-values",
      "params_func": "return {id: params.id}"
    },
    {
      "title": "子设备",
      "page":"device",
      "params_func": "return {gateway_id: params.id}"
    },
    {
      "title": "日志",
      "page":"device-log",
      "params_func": "return {id: params.id}"
    },
    {
      "title": "告警",
      "page":"alarm",
      "params_func": "return {device_id: params.id}"
    },
    {
      "title": "参数",
      "page":"device-settings",
      "params_func": "return {id: params.id}"
    },
    {
      "title": "轨迹",
      "page":"device-track",
      "params_func": "return {id: params.id}"
    },
    {
      "title": "场景",
      "page":"scene",
      "params_func": "return {gateway_id: params.id}"
    },
    {
      "title": "串口",
      "page":"serial",
      "params_func": "return {gateway_id: params.id}"
    },
    {
      "title": "定时任务",
      "page":"job",
      "params_func": "return {gateway_id: params.id}"
    },
    {
      "title": "数据绑定",
      "page":"binding",
      "params_func": "return {gateway_id: params.id}"
    }
  ]
}
