{
  "title": "网关串口管理",
  "template": "table",
  "toolbar": [
    {
      "label": "从网关读取",
      "icon": "sync",
      "type": "button",
      "action": {
        "type": "script",
        "script": "this.request.post('device/'+this.params.gateway_id+'/action/database', {operator:'find', database:'serial'}).subscribe(res=>{ this.on_device_serials(res.data) })"
      }
    },
    {
      "label": "下载到网关",
      "icon": "download",
      "type": "button",
      "confirm": "确认下载到网关？",
      "action": {
        "type": "script",
        "script": "this.request.get('device/'+this.params.gateway_id+'/download/serial').subscribe(res=>{})"
      }
    }
  ],
  "keywords": [
    "id",
    "name"
  ],
  "operators": [
    {
      "icon": "eye",
      "action": {
        "type": "dialog",
        "page": "serial-detail",
        "params_func": "return {id: data.id, gateway_id:data.gateway_id}"
      }
    },
    {
      "icon": "edit",
      "action": {
        "type": "dialog",
        "page":"serial-edit",
        "params_func": "return {id: data.id, gateway_id:data.gateway_id}",
        "after_close": "this.load()"
      }
    }
  ],
  "batch": true,
  "columns": [
    {
      "key": "id",
      "label": "ID",
      "action": {
        "type": "page",
        "page":"serial-detail",
        "params_func": "return {id: data.id, gateway_id: data.gateway_id}"
      }
    },
    {
      "key": "name",
      "label": "名称"
    },
    {
      "key": "port",
      "label": "序号"
    },
    {
      "key": "baud_rate",
      "label": "波特率"
    },
    {
      "key": "data_bits",
      "label": "字长"
    },
    {
      "key": "stop_bits",
      "label": "停止位"
    },
    {
      "key": "parity",
      "label": "检验位"
    },
    {
      "key": "rs485_gpio",
      "label": "485GPIO"
    },
    {
      "key": "protocol",
      "label": "协议"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "boolean"
    },
    {
      "key": "created",
      "label": "日期",
      "type": "date"
    }
  ],
  "search_api": "table/serial/search",
  "mount": "if(this.params.gateway_id) this.filter.gateway_id=this.params.gateway_id",
  "methods": {
    "on_device_serials": ["serials", "if(serials && serials.length) { this.delete_serials(); serials.map(s=>this.push_serial(s)); }"],
    "delete_serials": "this.data.map(s=> this.request.get('table/serial/delete/'+s.id+'/'+s.gateway_id).subscribe(()=>{}) ); this.data=[]",
    "push_serial": ["serial", "serial.gateway_id=this.params.gateway_id; this.data.push(serial); this.insert_serial(serial)"],
    "insert_serial": ["serial", "this.request.post('table/serial/create', serial).subscribe(()=>{})"]
  }
}
