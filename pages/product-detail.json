{
  "title": "产品详情",
  "template": "info",
  "toolbar": [
    {
      "icon": "edit",
      "type": "button",
      "label": "编辑",
      "action": {
        "type": "dialog",
        "page":"product-edit",
        "params_func": "return {id: data.id}",
        "after_close": "this.load()"
      }
    },
    {
      "icon": "delete",
      "type": "button",
      "label": "删除",
      "confirm": "确认删除？",
      "action": {
        "type": "script",
        "script": "this.request.get('table/device/delete/'+data.id).subscribe(res=>{this.navigate('/page/product')})"
      }
    }
  ],
  "items": [
    {
      "key": "id",
      "label": "ID"
    },
    {
      "key": "name",
      "label": "名称"
    },
    {
      "key": "description",
      "label": "说明"
    },
    {
      "key": "type",
      "label": "类型"
    },
    {
      "key": "version",
      "label": "版本"
    },
    {
      "key": "protocol",
      "label": "协议"
    },
    {
      "key": "gateway",
      "label": "网关",
      "type": "boolean"
    },
    {
      "key": "smart",
      "label": "智能",
      "type": "boolean"
    },
    {
      "key": "programmable",
      "label": "可编程",
      "type": "boolean"
    },
    {
      "key": "locatable",
      "label": "支持定位",
      "type": "boolean"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "boolean"
    }
  ],
  "load_api": "table/product/detail/:id",
  "tabs": [
    {
      "title": "产品设备",
      "page":"device",
      "params_func": "return {product_id: params.id}"
    },
    {
      "title": "物模型",
      "page":"product-setting-model",
      "params_func": "return {id: params.id}"
    },
    {
      "title": "配置参数",
      "page":"product-setting-setting",
      "params_func": "return {id: params.id}"
    },
    {
      "title": "设备操作",
      "page":"product-setting-action",
      "params_func": "return {id: params.id}"
    },
    {
      "title": "数值检查",
      "page":"product-setting-validator",
      "params_func": "return {id: params.id}"
    },
    {
      "title": "固件版本",
      "page":"version",
      "params_func": "return {product_id: params.id}"
    },
    {
      "title": "物模型(旧)",
      "page":"product-model",
      "params_func": "return {id: params.id}"
    }
  ]
}
