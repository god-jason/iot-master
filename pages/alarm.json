{
    "title": "报警日志",
    "template": "table",
    "toolbar": [
        {
            "label": "批量删除",
            "icon": "delete",
            "type": "button",
            "confirm": "确认批量删除？",
            "action": {
                "type": "script",
                "script": "this.table.selects.forEach(id=>this.request.get('table/alarm/delete/'+id).subscribe(res=>{this.load()}))"
            }
        },
        {
            "key": "keyword",
            "type": "text",
            "placeholder": "请输入关键字"
        },
        {
            "type": "button",
            "icon": "search",
            "label": "搜索",
            "action": {
                "type": "script",
                "script": "this.keyword=this.toolbar.value.keyword; this.load()"
            }
        }
    ],
    "keywords": [
        "title",
        "message"
    ],
    "operators": [
        {
            "icon": "delete",
            "title": "删除",
            "confirm": "确认删除？",
            "action": {
                "type": "script",
                "script": "this.request.get('table/alarm/delete/'+data.id).subscribe(res=>{this.load()})"
            }
        }
    ],
    "batch": true,
    "columns": [
        {
            "key": "id",
            "label": "ID"
        },
        {
            "key": "device_id",
            "label": "设备ID",
            "action": {
                "type": "page",
                "page": "device-detail",
                "params_func": "return {id: data.device_id}"
            }
        },
        {
            "key": "group_id",
            "label": "组织ID",
            "action": {
                "type": "page",
                "page": "group-detail",
                "params_func": "return {id: data.group_id}"
            }
        },
        {
            "key": "title",
            "label": "标题"
        },
        {
            "key": "message",
            "label": "消息"
        },
        {
            "key": "level",
            "label": "等级"
        },
        {
            "key": "created",
            "label": "日期",
            "type": "date"
        }
    ],
    "search_api": "table/alarm/search",
    "mount": "if(this.params.device_id)this.filter.device_id=this.params.device_id;if(this.params.group_id)this.filter.group_id=this.params.group_id;"
}
