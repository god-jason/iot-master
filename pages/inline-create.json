{
  "title": "创建内联设备",
  "template": "form",
  "toolbar": [
    {
      "type": "button",
      "label": "选择产品ID",
      "action": {
        "type": "dialog",
        "page": "product-choose",
        "after_close": "this.editor.patchValue({product_id: result.id})"
      }
    },
    {
      "type": "button",
      "label": "选择网关ID",
      "action": {
        "type": "dialog",
        "page": "device-choose",
        "after_close": "this.editor.patchValue({gateway_id: result.id})"
      }
    }
  ],
  "fields": [
    {
      "key": "id",
      "label": "ID",
      "type": "text",
      "placeholder": "默认随机ID"
    },
    {
      "key": "name",
      "label": "名称",
      "type": "text"
    },
    {
      "key": "description",
      "label": "说明",
      "type": "text"
    },
    {
      "key": "product_id",
      "label": "产品ID",
      "type": "text"
    },
    {
      "key": "gateway_id",
      "label": "网关ID",
      "type": "text"
    },
    {
      "key": "link_id",
      "label": "连接ID",
      "type": "text"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "switch"
    }
  ],
  "submit_api": "table/inline/create",
  "submit_success": "this.navigate('/page/gateway-detail?id='+this.params.gateway_id)",
  "mounts": [
    "this.data.product_id=this.params.product_id;",
    "this.data.gateway_id=this.params.gateway_id;",
    "this.get_extend_fields()"
  ],
  "methods": {
    "get_extend_fields": "this.request.get('device/extend/fields').subscribe(res=>{if(res.error)return; res.data.map(f=>this.content.fields.push(f)) })"
  }
}
