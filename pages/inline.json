{
  "title": "内联设备",
  "template": "table",
  "toolbar": [
    {
      "label": "创建",
      "icon": "plus",
      "type": "button",
      "action": {
        "type": "dialog",
        "page": "inline-create",
        "params_func": "return {gateway_id: this.params.gateway_id}",
        "after_close": "this.load()"
      },
      "admin": true
    },
    {
      "label": "从网关读取",
      "icon": "sync",
      "type": "button",
      "action": {
        "type": "script",
        "script": "this.from_gateway()"
      }
    },
    {
      "label": "下载到网关",
      "icon": "download",
      "type": "button",
      "confirm": "确认下载到网关？",
      "action": {
        "type": "script",
        "script": "this.request.get('device/'+this.params.gateway_id+'/download/inline').subscribe(res=>{})"
      }
    }
  ],
  "keywords": [
    "id",
    "name"
  ],
  "operators": [
    {
      "icon": "edit",
      "action": {
        "type": "dialog",
        "page": "inline-edit",
        "params_func": "return {id: data.id, gateway_id: data.gateway_id}",
        "after_close": "this.load()"
      }
    },
    {
      "icon": "delete",
      "title": "删除",
      "confirm": "确认删除？",
      "action": {
        "type": "script",
        "script": "this.request.get('table/inline/delete/'+data.id+'/'+data.gateway_id).subscribe(res=>{this.load()})"
      },
      "admin": true
    }
  ],
  "batch": true,
  "columns": [
    {
      "key": "id",
      "label": "ID"
    },
    {
      "key": "product_id",
      "label": "产品ID",
      "action": {
        "type": "page",
        "page": "product-detail",
        "params_func": "return {id: data.product_id}"
      }
    },
    {
      "key": "name",
      "label": "名称"
    },
    {
      "key": "description",
      "label": "说明"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "boolean"
    },
    {
      "key": "created",
      "label": "日期",
      "type": "date"
    }
  ],
  "search_api": "table/inline/search",
  "mounts": [
    "if(this.params.gateway_id)this.filter.gateway_id=this.params.gateway_id;",
    "this.get_extend_fields()"
  ],
  "methods": {
    "from_gateway": "this.request.post('device/'+this.params.gateway_id+'/action/database', {operator:'find', database:'inline'}).subscribe(res=>{ this.on_gatway_data(res.data) })",
    "on_gatway_data": ["ds", "if(ds && ds.length) { this.delete_all(); this.data=ds; setTimeout(()=>this.insert_all(), 1000);  }"],
    "delete_all": "this.data.map(s=> this.request.get('table/inline/delete/'+s.id+'/'+s.gateway_id).subscribe(()=>{}) ); this.data=[]",
    "insert_all": "this.data.map(s => s.gateway_id=this.params.gateway_id); this.data.map(s=> this.request.post('table/inline/create', s).subscribe(()=>{}) );",
    "get_extend_fields": "this.request.get('device/extend/fields').subscribe(res=>{if(res.error)return; res.data.map(f=>this.content.columns.push(f)) })"
  }
}
