{
  "title": "内联设备",
  "template": "table",
  "toolbar": [
    {
      "label": "创建",
      "icon": "plus",
      "type": "button",
      "action": {
        "type": "dialog",
        "page": "inline-create",
        "params_func": "return {product_id: this.params.product_id, gateway_id: this.params.gateway_id}",
        "after_close": "this.load()"
      }
    },
    {
      "label": "批量删除",
      "icon": "delete",
      "type": "button",
      "confirm": "确认批量删除？",
      "action": {
        "type": "script",
        "script": "this.table.selects.forEach(id=>this.request.get('table/inline/delete/'+id+'/'+this.params.gateway_id).subscribe(res=>{this.load()}))"
      }
    },
    {
      "key": "keyword",
      "type": "text",
      "placeholder": "请输入关键字"
    },
    {
      "type": "button",
      "icon": "search",
      "label": "搜索",
      "action": {
        "type": "script",
        "script": "this.keyword=this.toolbar.value.keyword; this.load()"
      }
    },
    {
      "label": "下载到网关",
      "icon": "download",
      "type": "button",
      "confirm": "确认下载到网关？",
      "action": {
        "type": "script",
        "script": "this.request.get('device/'+this.params.gateway_id+'/download/inline').subscribe(res=>{})"
      }
    }
  ],
  "keywords": [
    "id",
    "name"
  ],
  "operators": [
    {
      "icon": "edit",
      "action": {
        "type": "dialog",
        "page": "inline-edit",
        "params_func": "return {id: data.id, gateway_id: data.gateway_id}",
        "after_close": "this.load()"
      }
    },
    {
      "icon": "delete",
      "title": "删除",
      "confirm": "确认删除？",
      "action": {
        "type": "script",
        "script": "this.request.get('table/inline/delete/'+data.id+'/'+data.gateway_id).subscribe(res=>{this.load()})"
      }
    }
  ],
  "batch": true,
  "columns": [
    {
      "key": "id",
      "label": "ID"
    },
    {
      "key": "product_id",
      "label": "产品ID",
      "action": {
        "type": "page",
        "page": "product-detail",
        "params_func": "return {id: data.product_id}"
      }
    },
    {
      "key": "name",
      "label": "名称"
    },
    {
      "key": "description",
      "label": "说明"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "boolean"
    },
    {
      "key": "created",
      "label": "日期",
      "type": "date"
    }
  ],
  "search_api": "table/inline/search",
  "mounts": [
    "if(this.params.gateway_id)this.filter.gateway_id=this.params.gateway_id;",
    "this.get_extend_fields()"
  ],
  "methods": {
    "get_extend_fields": "this.request.get('device/extend/fields').subscribe(res=>{if(res.error)return; res.data.map(f=>this.content.columns.push(f)) })"
  }
}
