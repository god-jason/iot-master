{
  "title": "数据绑定",
  "template": "table",
  "toolbar": [
    {
      "label": "创建",
      "icon": "plus",
      "type": "button",
      "action": {
        "type": "page",
        "page":"binding-create",
        "params_func": "return {gateway_id: this.params.gateway_id}"
      }
    },
    {
      "label": "批量删除",
      "icon": "delete",
      "type": "button",
      "confirm": "确认批量删除？",
      "action": {
        "type": "script",
        "script": "this.table.selects.forEach(id=>this.request.get('table/binding/delete/'+id).subscribe(res=>{this.load()}))"
      }
    },
    {
      "key": "keyword",
      "type": "text",
      "placeholder": "请输入关键字"
    },
    {
      "type": "button",
      "icon": "search",
      "label": "搜索",
      "action": {
        "type": "script",
        "script": "this.keyword=this.toolbar.value.keyword; this.load()"
      }
    },
    {
      "label": "下载到网关",
      "icon": "download",
      "type": "button",
      "confirm": "确认下载到网关？",
      "action": {
        "type": "script",
        "script": "this.request.get('device/'+this.params.gateway_id+'/download/binding').subscribe(res=>{})"
      }
    }
  ],
  "keywords": [
    "id",
    "name"
  ],
  "operators": [
    {
      "icon": "edit",
      "action": {
        "type": "page",
        "page":"binding-edit",
        "params_func": "return {id: data.id}"
      }
    },
    {
      "icon": "delete",
      "title": "删除",
      "confirm": "确认删除？",
      "action": {
        "type": "script",
        "script": "this.request.get('table/binding/delete/'+data.id).subscribe(res=>{this.load()})"
      }
    }
  ],
  "batch": true,
  "columns": [
    {
      "key": "id",
      "label": "ID"
    },
    {
      "key": "name",
      "label": "名称"
    },
    {
      "key": "device1",
      "label": "设备1"
    },
    {
      "key": "device2",
      "label": "设备2"
    },
    {
      "key": "forward",
      "label": "右向"
    },
    {
      "key": "backward",
      "label": "左向"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "boolean"
    },
    {
      "key": "created",
      "label": "日期",
      "type": "date"
    }
  ],
  "search_api": "table/binding/search",
  "mount": "if(this.params.gateway_id)this.filter.gateway_id=this.params.gateway_id"
}
