{
  "title": "数据绑定",
  "template": "table",
  "toolbar": [
    {
      "label": "创建",
      "icon": "plus",
      "type": "button",
      "action": {
        "type": "dialog",
        "page":"binding-create",
        "params_func": "return {gateway_id: this.params.gateway_id}",
        "after_close": "this.load()"
      }
    },
    {
      "label": "从网关读取",
      "icon": "sync",
      "type": "button",
      "action": {
        "type": "script",
        "script": "this.from_gateway()"
      }
    },
    {
      "label": "下载到网关",
      "icon": "download",
      "type": "button",
      "confirm": "确认下载到网关？",
      "action": {
        "type": "script",
        "script": "this.request.get('device/'+this.params.gateway_id+'/download/binding').subscribe(res=>{})"
      }
    }
  ],
  "keywords": [
    "id",
    "name"
  ],
  "operators": [
    {
      "icon": "edit",
      "action": {
        "type": "dialog",
        "page":"binding-edit",
        "params_func": "return {id: data.id}",
        "after_close": "this.load()"
      }
    },
    {
      "icon": "delete",
      "title": "删除",
      "confirm": "确认删除？",
      "action": {
        "type": "script",
        "script": "this.request.get('table/binding/delete/'+data.id+'/'+data.gateway_id).subscribe(res=>{this.load()})"
      }
    }
  ],
  "batch": true,
  "columns": [
    {
      "key": "id",
      "label": "ID"
    },
    {
      "key": "name",
      "label": "名称"
    },
    {
      "key": "device1",
      "label": "设备1"
    },
    {
      "key": "device2",
      "label": "设备2"
    },
    {
      "key": "forward",
      "label": "右向"
    },
    {
      "key": "backward",
      "label": "左向"
    },
    {
      "key": "disabled",
      "label": "禁用",
      "type": "boolean"
    },
    {
      "key": "created",
      "label": "日期",
      "type": "date"
    }
  ],
  "search_api": "table/binding/search",
  "mount": "if(this.params.gateway_id) this.filter.gateway_id=this.params.gateway_id",
  "methods": {
    "from_gateway": "this.request.post('device/'+this.params.gateway_id+'/action/database', {operator:'find', database:'binding'}).subscribe(res=>{ this.on_gatway_data(res.data) })",
    "on_gatway_data": ["ds", "if(ds && ds.length) { this.delete_all(); this.data=ds; setTimeout(()=>this.insert_all(), 1000);  }"],
    "delete_all": "this.data.map(s=> this.request.get('table/binding/delete/'+s.id+'/'+s.gateway_id).subscribe(()=>{}) ); this.data=[]",
    "insert_all": "this.data.map(s => s.gateway_id=this.params.gateway_id); this.data.map(s=> this.request.post('table/binding/create', s).subscribe(()=>{}) );"
  }
}
