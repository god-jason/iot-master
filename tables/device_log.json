{
  "name": "device_log",
  "comment": "设备日志",
  "joins": [
    {
      "table": "device",
      "local": "device_id",
      "foreign": "id",
      "fields": {
        "name": "device_name"
      }
    },
    {
      "table": "user",
      "local": "user_id",
      "foreign": "id",
      "fields": {
        "name": "user_name"
      }
    }
  ],
  "fields": [
    {
      "name": "id",
      "comment": "ID",
      "type": "int64",
      "primary": true,
      "increment": true
    },
    {
      "name": "device_id",
      "comment": "设备ID",
      "type": "string",
      "length": 50,
      "indexed": true
    },
    {
      "name": "user_id",
      "comment": "用户ID",
      "type": "string",
      "length": 50,
      "indexed": true
    },
    {
      "name": "content",
      "comment": "内容",
      "type": "text",
      "json": true
    },
    {
      "name": "created",
      "comment": "创建时间",
      "type": "datetime",
      "created": true
    }
  ]
}
