{
  "name": "binding",
  "comment": "设备绑定",
  "joins": [
    {
      "table": "device",
      "local": "gateway_id",
      "foreign": "id",
      "fields": {
        "name": "gateway_name"
      }
    },
    {
      "table": "device",
      "local": "device1",
      "foreign": "id",
      "fields": {
        "name": "device1_name"
      }
    },
    {
      "table": "device",
      "local": "device2",
      "foreign": "id",
      "fields": {
        "name": "device2_name"
      }
    }
  ],
  "fields": [
    {
      "name": "id",
      "comment": "ID",
      "type": "string",
      "length": 50,
      "primary": true
    },
    {
      "name": "gateway_id",
      "comment": "设备ID",
      "type": "string",
      "length": 50,
      "primary": true
    },
    {
      "name": "name",
      "comment": "名称",
      "type": "string",
      "length": 50
    },
    {
      "name": "device1",
      "comment": "设备1",
      "type": "string",
      "length": 50
    },
    {
      "name": "device2",
      "comment": "设备2",
      "type": "string",
      "length": 50
    },
    {
      "name": "forward",
      "comment": "右向",
      "type": "bool",
      "default": "false"
    },
    {
      "name": "backward",
      "comment": "左向",
      "type": "bool",
      "default": "false"
    },
    {
      "name": "disabled",
      "comment": "禁用",
      "type": "bool",
      "default": "false"
    },
    {
      "name": "updated",
      "comment": "更新时间",
      "type": "datetime",
      "updated": true
    },
    {
      "name": "created",
      "comment": "创建时间",
      "type": "datetime",
      "created": true
    }
  ]
}