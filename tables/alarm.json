{
  "name": "alarm",
  "comment": "报警日志",
  "joins": [
    {
      "table": "device",
      "local": "device_id",
      "foreign": "id",
      "fields": {
        "name": "device_name"
      }
    },
    {
      "table": "group",
      "local": "group_id",
      "foreign": "id",
      "fields": {
        "name": "group_name"
      }
    }
  ],
  "fields": [
    {
      "name": "id",
      "comment": "ID",
      "increment": true,
      "type": "int64",
      "primary": true
    },
    {
      "name": "device_id",
      "comment": "设备ID",
      "type": "string",
      "length": 50,
      "indexed": true
    },
    {
      "name": "group_id",
      "comment": "组织ID",
      "type": "string",
      "length": 50,
      "indexed": true
    },
    {
      "name": "title",
      "comment": "标题",
      "type": "string",
      "length": 50
    },
    {
      "name": "message",
      "comment": "内容",
      "type": "string",
      "length": 256
    },
    {
      "name": "level",
      "comment": "等级",
      "type": "uint8",
      "indexed": true
    },
    {
      "name": "type",
      "comment": "类型",
      "type": "string",
      "length": 50,
      "indexed": true
    },
    {
      "name": "status",
      "comment": "状态",
      "type": "uint8",
      "indexed": true
    },
    {
      "name": "handled_time",
      "comment": "处理时间",
      "type": "datetime"
    },
    {
      "name": "handled_by",
      "comment": "处理人",
      "type": "string",
      "length": 50
    },
    {
      "name": "created",
      "comment": "创建时间",
      "type": "datetime",
      "created": true
    }
  ],
  "disable_insert": true,
  "disabled_update": true
}
