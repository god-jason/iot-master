{
  "name": "product_setting",
  "comment": "产品参数",
  "joins": [
    {
      "table": "product",
      "local": "id",
      "foreign": "id",
      "fields": {
        "name": "product_name"
      }
    }
  ],
  "fields": [
    {
      "name": "id",
      "comment": "产品ID",
      "type": "string",
      "length": 50,
      "primary": true
    },
    {
      "name": "name",
      "comment": "参数名称",
      "type": "string",
      "length": 50
    },
    {
      "name": "version",
      "comment": "版本号",
      "type": "int"
    },
    {
      "name": "content",
      "comment": "内容",
      "type": "text",
      "json": true
    },
    {
      "name": "created",
      "comment": "创建时间",
      "type": "datetime",
      "created": true
    },
    {
      "name": "updated",
      "comment": "更新时间",
      "type": "datetime",
      "updated": true
    }
  ]
}
