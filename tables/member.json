{
  "name": "member",
  "comment": "组织成员",
  "joins": [
    {
      "table": "user",
      "local": "user_id",
      "foreign": "id",
      "fields": {
        "name": "user_name"
      }
    },
    {
      "table": "group",
      "local": "group_id",
      "foreign": "id",
      "fields": {
        "name": "group_name"
      }
    }
  ],
  "fields": [
    {
      "name": "group_id",
      "comment": "组织ID",
      "type": "string",
      "length": 50,
      "primary": true
    },
    {
      "name": "user_id",
      "comment": "用户ID",
      "type": "string",
      "length": 50,
      "primary": true
    },
    {
      "name": "disabled",
      "comment": "禁用",
      "type": "bool",
      "default": "false"
    },
    {
      "name": "created",
      "comment": "创建时间",
      "type": "datetime",
      "created": true
    }
  ]
}
